# ========================================
# zm-auto VPS 部署配置（复制为 .env 后修改）
# cp .env.example .env
# ========================================

# --- 必填 ---

# 你的域名（DNS A 记录必须先指向 VPS 公网 IP）
# Caddy 会自动申请 Let's Encrypt 证书
DOMAIN=zm-auto.example.com

# 登录用户名（建议不要用 admin，改成难猜的）
WEB_USERNAME=admin

# 登录密码（强密码！至少 16 位混合大小写+数字+符号）
WEB_PASSWORD=please_change_me_to_a_strong_password

# Session cookie 签名密钥（随机 32+ 字节）
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(32))"
# 或：openssl rand -base64 32
SECRET_KEY=please_generate_a_random_secret_key_here
